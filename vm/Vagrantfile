# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.hostname = "vigilan-ids"

  # Private network - VM accessible at 192.168.56.10
  config.vm.network "private_network", ip: "192.168.56.10"

  # Synced folder: Suricata writes eve.json here, host reads it
  config.vm.synced_folder "./shared", "/vagrant_shared",
    owner: "root",
    group: "root",
    mount_options: ["dmode=777", "fmode=666"]

  config.vm.provider "virtualbox" do |vb|
    vb.name = "vigilan-ids"
    vb.memory = 2048
    vb.cpus = 2
  end

  config.vm.provision "shell", path: "provision/setup-suricata.sh"
end
